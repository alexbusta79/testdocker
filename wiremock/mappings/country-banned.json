{
  "priority": 1,
  "request": {
    "method": "GET",
    "urlPathPattern": "/countries/[n-zN-Z][a-zA-Z]"
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "name": "{{request.pathSegments.[1]}}",
      "isBanned": true
    },
    "transformers": ["response-template"]
  }
}
